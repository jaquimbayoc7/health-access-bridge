# ============================================================
# AMBIENTE: QA / STAGING
# Rama: staging | Uso: pruebas de integración y E2E
# ============================================================

# App
ENVIRONMENT=staging
DEBUG=false

# Backend
BACKEND_PORT=8000
ALLOWED_ORIGINS=https://hab-frontend-qa.onrender.com

# Base de datos (Render PostgreSQL - QA instance)
DATABASE_URL=postgresql://hab_user:CHANGE_ME@hab-db-qa.render.com:5432/hab_qa

# JWT
JWT_SECRET=qa-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# Admin por defecto (seed)
DEFAULT_ADMIN_EMAIL=admin@hab-qa.local
DEFAULT_ADMIN_PASSWORD=QaAdmin123!

# Modelo predictivo (HybridModelDisability)
PREDICTION_API_URL=https://hybridmodeldisability.onrender.com
PREDICTION_API_KEY=qa-prediction-key

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=sk-your-qa-key-here

# Frontend
VITE_API_BASE_URL=https://hybridmodeldisability.onrender.com
VITE_ENVIRONMENT=staging
