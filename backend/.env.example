# Ejemplo de variables de entorno necesarias para Render
# Copia este archivo a .env local y completa los valores

# ============================================
# RENDER - Configuración de Producción
# ============================================

# Base de datos PostgreSQL URL (Render la proporciona automáticamente)
# Formato: postgresql+psycopg2://usuario:contraseña@host:port/nombre_db
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Clave secreta para JWT (Render puede generarla automáticamente)
# Debe ser una cadena segura y aleatoria de al menos 32 caracteres
SECRET_KEY=tu-clave-secreta-muy-segura-aqui-minimo-32-caracteres

# ============================================
# DESARROLLO LOCAL
# ============================================

# Para desarrollo local, puedes usar SQLite
# DATABASE_URL=sqlite:///./test.db

# O configura una BD PostgreSQL local
# DATABASE_URL=postgresql://localhost/disability_db
