# ──────────────────────────────────────────────────────
# Health Access Bridge — Frontend Environment Variables
# Copia este archivo como .env y ajusta la URL según el
# ambiente en el que vayas a trabajar localmente.
# ──────────────────────────────────────────────────────

# URL del backend HAB según ambiente:
#   DEV:  https://hab-backend-dev.onrender.com
#   QA:   https://hab-backend-qa.onrender.com
#   PROD: https://hab-backend.onrender.com
VITE_API_BASE_URL=https://hab-backend-dev.onrender.com

# Ambiente actual (development | staging | production)
VITE_ENVIRONMENT=development
