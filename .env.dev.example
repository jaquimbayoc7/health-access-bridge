# ============================================================
# AMBIENTE: DEVELOPMENT
# Rama: develop | Uso: desarrollo local y pruebas rápidas
# ============================================================

# App
ENVIRONMENT=development
DEBUG=true

# Backend
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Base de datos (Docker local)
DATABASE_URL=postgresql://hab_user:hab_password@localhost:5432/hab_dev

# JWT
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Admin por defecto (seed)
DEFAULT_ADMIN_EMAIL=admin@hab-dev.local
DEFAULT_ADMIN_PASSWORD=Admin123!

# Modelo predictivo (HybridModelDisability)
PREDICTION_API_URL=https://hybridmodeldisability.onrender.com
PREDICTION_API_KEY=dev-prediction-key

# LLM (usar modelo ligero en dev)
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=sk-your-dev-key-here

# Frontend
VITE_API_BASE_URL=https://hybridmodeldisability.onrender.com
VITE_ENVIRONMENT=development
