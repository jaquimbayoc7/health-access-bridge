# ============================================================
# AMBIENTE: PRODUCTION
# Rama: master | Uso: versión estable para usuarios finales
# ============================================================

# App
ENVIRONMENT=production
DEBUG=false

# Backend
BACKEND_PORT=8000
ALLOWED_ORIGINS=https://hab-frontend.onrender.com

# Base de datos (Render PostgreSQL - Production instance)
DATABASE_URL=postgresql://hab_user:CHANGE_ME@hab-db-prod.render.com:5432/hab_prod

# JWT
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Admin por defecto (seed - solo primer deploy)
DEFAULT_ADMIN_EMAIL=admin@hab.health
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Modelo predictivo (HybridModelDisability)
PREDICTION_API_URL=https://hybridmodeldisability.onrender.com
PREDICTION_API_KEY=CHANGE_ME_PRODUCTION_KEY

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
OPENAI_API_KEY=sk-your-prod-key-here

# Frontend
VITE_API_BASE_URL=https://hybridmodeldisability.onrender.com
VITE_ENVIRONMENT=production
